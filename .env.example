# Harbourview — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.

# Supabase public client config
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Supabase server-only service role. Never expose through NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=replace-with-rotated-service-role-key

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Shared production rate limiting. Required in production.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token

# Test accounts (dev/test only — never production)
TEST_ADMIN_EMAIL=admin@harbourview.io
TEST_ADMIN_PASSWORD=
TEST_ANALYST_EMAIL=analyst@harbourview.io
TEST_ANALYST_PASSWORD=
