# Harbourview — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Test accounts (dev/test only — never production)
TEST_ADMIN_EMAIL=admin@harbourview.io
TEST_ADMIN_PASSWORD=
TEST_ANALYST_EMAIL=analyst@harbourview.io
TEST_ANALYST_PASSWORD=
